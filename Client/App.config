<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <system.serviceModel>
    <bindings>
      <netTcpBinding>
        <binding name="WeatherTcpBinding"
                 maxReceivedMessageSize="1048576"
                 openTimeout="00:00:10"
                 sendTimeout="00:00:30"
                 receiveTimeout="00:10:00" />
      </netTcpBinding>
    </bindings>

    <client>
      <endpoint name="WeatherServiceEndpoint"
                address="net.tcp://localhost:4000/WeatherService"
                binding="netTcpBinding"
                bindingConfiguration="WeatherTcpBinding"
                contract="Common.IWeatherService" />
    </client>
  </system.serviceModel>

  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
  </startup>
</configuration>
